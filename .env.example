# ============================================================
# AI 内容机器人 — 环境变量配置
# ============================================================
# 复制本文件为 .env，填入实际值
# cp .env.example .env

# ---------- 写作引擎 ----------
# 默认使用 MiniMax（OpenAI-compatible），无需 Anthropic Key
MINIMAX_API_KEY=sk-cp-your-key-here

# 如需切换回 Claude，可改为：
# ANTHROPIC_API_KEY=sk-ant-xxxx

# ---------- 数据源 ----------
# GitHub Token（推荐填写，避免 API 限速 60次/小时 → 5000次/小时）
GITHUB_TOKEN=github_pat_xxxx

# X/Twitter Bearer Token（无 Token 走 Nitter 降级方案）
TWITTER_BEARER_TOKEN=AAAAAxx

# ---------- 发布平台 ----------
# 微信公众号（baoyu-skills post-to-wechat）
WECHAT_APP_ID=wx_xxxx
WECHAT_APP_SECRET=xxxx
